# MongoDB baglanti bilgileri (mağaza teslimat kuyrugu VE login/kredi sistemi
# icin). Bu, Minecraft sunucunuzdaki McDelivery plugin'inin config.yml
# dosyasindaki "mongo.uri" / "mongo.database" ile AYNI veritabanini
# gostermelidir - iki taraf da ayni "users", "products", "purchase_requests",
# "credit_requests", "categories" koleksiyonlarini paylasir.
MONGODB_URI=
MONGODB_DB=

# /api/queue, /api/queue/complete endpoint'lerini korumak icin
# Minecraft plugin'inizin de kullanacagi gizli anahtar. Bu deger ayrica
# admin panel girisi ve kullanici/admin oturum cookie'lerini imzalamak
# icin de temel alinir (bkz. lib/auth.ts).
SECRET_KEY=
