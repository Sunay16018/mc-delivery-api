# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL=""

# --- ZEFIRCRAFT PORTAL SETTINGS ---

# MONGODB_URI: Connection string for your MongoDB. 
# Highly recommended on production to store player data, purchases, categories and support tickets durably!
# If left empty, the server falls back to a local JSON file (.data/db.json).
MONGODB_URI=""

# ADMIN_USERNAME: Username for the administrator dashboard login (default: "admin")
ADMIN_USERNAME="admin"

# ADMIN_PASSWORD: Password for the administrator dashboard login (default: "admin123")
ADMIN_PASSWORD="admin123"

# JWT_SECRET: Private key used to sign session tokens securely.
JWT_SECRET="zefircraft_secret_session_key_555"

# SECRET_KEY: The API token shared between this portal and the Spigot McDelivery plugin on your Minecraft server.
SECRET_KEY="zefircraft_minecraft_spigot_api_secret_key"

# RESEND_API_KEY: API Key for Resend mail system, if you want to enable automatic email notifications.
RESEND_API_KEY=""
